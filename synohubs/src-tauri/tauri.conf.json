{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SynoHubs",
  "version": "0.1.0",
  "identifier": "com.synohubs.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SynoHubs",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "SynoHubs Team",
    "copyright": "© 2026 SynoHubs. All rights reserved.",
    "category": "Utility",
    "shortDescription": "Multi-NAS Manager for Synology",
    "longDescription": "SynoHubs is a premium desktop application for managing multiple Synology NAS devices from one unified interface.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "allowDowngrades": true,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
