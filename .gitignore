# ============================================
# SynoHubs Monorepo — Unified .gitignore
# ============================================

# ── IDE / OS ──
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Flutter (synohubs_mobile) ──
synohubs_mobile/.dart_tool/
synohubs_mobile/.flutter-plugins
synohubs_mobile/.flutter-plugins-dependencies
synohubs_mobile/build/
synohubs_mobile/.metadata
synohubs_mobile/android/.gradle/
synohubs_mobile/android/local.properties
synohubs_mobile/android/app/google-services.json
synohubs_mobile/.wrangler/

# ── Tauri Desktop (synohubs) ──
synohubs/node_modules/
synohubs/dist/
synohubs/src-tauri/target/
synohubs/src-tauri/gen/

# ── Website (synohubs.com) ──
synohubs.com/node_modules/
synohubs.com/dist/
synohubs.com/.wrangler/

# ── General ──
node_modules/
*.log
*.lock
!pubspec.lock

# ── Secrets ──
*.jks
*.keystore
key.properties
.env
.env.*

# ── Gemini/Agent ──
.agent/
design-system/
mockups/
